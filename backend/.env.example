# Django secret key (use a strong random value in production)
SECRET_KEY=dev-secret-key-change-in-production

# Debug mode (set to False in production)
DEBUG=True

# Comma-separated list of allowed hosts (e.g. localhost,127.0.0.1,.onrender.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated CORS origins for frontend (e.g. http://localhost:5173,https://your-app.vercel.app)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
